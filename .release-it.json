{
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "angular",
      "infile": false
    }
  },
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}",
    "push": true
  },
  "github": { "release": false },
  "npm":    { "publish": false }
}
