{
  "name": "devtier",
  "version": "0.4.11",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "collect:users": "tsx --env-file=.env.local scripts/collect-users.ts",
    "collect:scores": "tsx --env-file=.env.local scripts/collect-scores.ts",
